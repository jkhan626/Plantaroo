{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true },
      "env": {
        "EAS_BUILD_NPM_INSTALL_COMMAND": "npm install --legacy-peer-deps"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": { "simulator": false },
      "env": {
        "EAS_BUILD_NPM_INSTALL_COMMAND": "npm install --legacy-peer-deps"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EAS_BUILD_NPM_INSTALL_COMMAND": "npm install --legacy-peer-deps"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "jkhan626@gmail.com",
        "appleTeamId": "AK6GDSF62K",
        "ascAppId": "PASTE_APP_STORE_CONNECT_APP_ID"
      }
    }
  }
}
