{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true },
      "env": {
        "EAS_BUILD_NPM_INSTALL_COMMAND": "npm install --legacy-peer-deps"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": { "simulator": false },
      "env": {
        "EAS_BUILD_NPM_INSTALL_COMMAND": "npm install --legacy-peer-deps"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EAS_BUILD_NPM_INSTALL_COMMAND": "npm install --legacy-peer-deps",
        "SENTRY_ORG": "liftaroo",
        "SENTRY_PROJECT": "react-native"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "AK6GDSF62K",
        "ascAppId": "6778036982",
        "ascApiKeyPath": "./.secrets/asc.p8",
        "ascApiKeyId": "8ASZ7HGUY9",
        "ascApiKeyIssuerId": "7a4a3187-a6ce-47a8-9410-46b93308f9d0"
      }
    }
  }
}
