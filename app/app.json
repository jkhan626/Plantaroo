{
  "expo": {
    "name": "Plantaroo",
    "slug": "plantaroo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "plantaroo",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A0A",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jamalkhan.plantaroo",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": [
              "C617.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": [
              "35F9.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": [
              "E174.1"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.jamalkhan.plantaroo",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#159B46"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0A"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#30D158"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Plantaroo lets you pick a photo for each of your plants.",
          "cameraPermission": "Plantaroo uses the camera to take photos of your plants."
        }
      ],
      "expo-apple-authentication",
      "expo-web-browser",
      "expo-updates",
      [
        "@sentry/react-native/expo",
        {
          "organization": "liftaroo",
          "project": "react-native",
          "url": "https://sentry.io/"
        }
      ],
      "expo-quick-actions",
      "expo-secure-store",
      "expo-localization"
    ],
    "extra": {
      "googleIosClientId": "PASTE_IOS_CLIENT_ID.apps.googleusercontent.com",
      "googleWebClientId": "PASTE_WEB_CLIENT_ID.apps.googleusercontent.com",
      "eas": {
        "projectId": "5cd86768-cf71-4e06-8179-96dd03769dd2"
      }
    },
    "owner": "jkhan626",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5cd86768-cf71-4e06-8179-96dd03769dd2",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 10000
    }
  }
}
