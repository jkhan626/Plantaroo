rules_version = '2';

// Plantaroo — each signed-in user can read/write only their own data under
// users/{uid}/**. No cross-user access; unauthenticated access is denied.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Names-free watering summary published for the nightly "Water Plants"
    // Notion routine (counts + next-due dates only, no plant names/notes/
    // photos). World-readable so the cloud routine (not signed in) can fetch
    // it via the Firestore REST API; only a signed-in user (Jamal) can write.
    match /public/{doc} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
  }
}
