rules_version = '2';

// Plantaroo — each signed-in user can read/write only their own data under
// users/{uid}/**. No cross-user access; unauthenticated access is denied.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
